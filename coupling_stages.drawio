        <mxCell id="ilcXe3Gz7aXwLIzpjiaM-6" value="static class&#xa;TipCalculator&#xa;+ Calculate(decimal subtotal, decimal rate)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="ilcXe3Gz7aXwLIzpjiaM-1">
