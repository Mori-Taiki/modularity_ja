  <diagram name="⑤侵入結合 (Intrusive)" id="p5">
    <mxGraphModel dx="1386" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5_title" value="ステージ5 ☠ 侵入結合 (Intrusive Coupling)" style="text;html=1;align=center;fontSize=22;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="180" y="30" width="820" height="35" as="geometry" />
        </mxCell>
        <mxCell id="p5_subtitle" value="Dashboard が Checkout の内部テーブルを直接 SELECT — モジュール境界を完全に貫通" style="text;html=1;align=center;fontSize=14;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="180" y="70" width="840" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p5_co_module" value="Checkout モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="80" y="130" width="400" height="570" as="geometry" />
        </mxCell>
        <mxCell id="p5_co_ctx" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;internal class&lt;br&gt;CheckoutDbContext&lt;br&gt;+ DbSet PendingReceipts&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="130" y="200" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p5_co_row" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;internal class&lt;br&gt;PendingReceiptRow&lt;br&gt;  • Guid OrderId&lt;br&gt;  • decimal Subtotal&lt;br&gt;  • decimal Tax&lt;br&gt;  • decimal Tip&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="130" y="350" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p5_db" value="DB&#xa;schema: checkout&#xa;table: PendingReceipts" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="135" y="580" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p5_dash_module" value="Dashboard モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="650" y="130" width="440" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p5_dash_view" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;class PendingCheckoutsView&lt;br&gt;&lt;br&gt;db.Query&amp;lt;...&amp;gt;(&lt;br&gt;  &quot;SELECT OrderId, Subtotal, Tax, Tip&quot;&lt;br&gt;  &quot;  FROM checkout.PendingReceipts&quot;&lt;br&gt;)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="730" y="250" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p5_e1" value="&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 22px; background-color: rgb(251, 251, 251);&quot;&gt;☠&lt;/span&gt;直接 SQL&lt;br&gt;（モジュール境界を貫通）" style="endArrow=classic;html=1;fontSize=12;strokeColor=#b85450;strokeWidth=3;fontStyle=1;" parent="1" source="p5_dash_view" target="p5_db" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_anno" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;☠ 利用側が知っているもの: Checkout の 内部テーブル構造・カラム名・スキーマ名&lt;br&gt;☠ Checkout チームは「外から内部テーブルが見られている」ことを 知らない&lt;br&gt;☠ カラム名変更・テーブル移動だけで Dashboard が サイレントに 壊れる（コンパイルは通る）&lt;br&gt;→ 「機能結合」が「侵入結合」に変化した — 最も頑固で、最も検出が難しい結合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9e9;strokeColor=#b85450;fontSize=12;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" parent="1" vertex="1">
