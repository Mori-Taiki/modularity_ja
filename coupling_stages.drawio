        </mxCell>
        <mxCell id="p4_subtitle" parent="1" style="text;html=1;align=center;fontSize=14;fontColor=#666666;" value="PaymentUtil で「共通化」— bool フラグで利用側が内部分岐を制御する" vertex="1">
          <mxGeometry height="25" width="1200" x="100" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p4_oc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="OrderController&#xa;(Checkout 利用側)" vertex="1">
