  <diagram name="③機能結合-重複 (Functional-Dup)" id="p3">
    <mxGraphModel dx="1291" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3_title" value="ステージ3 ⚠ 機能結合 (Functional Coupling) — 重複した機能" style="text;html=1;align=center;fontSize=22;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="180" y="70" width="770" height="35" as="geometry" />
        </mxCell>
        <mxCell id="p3_subtitle" value="値オブジェクトを消し Refund にロジックをコピペ — ビジネスルールが複数箇所に重複" style="text;html=1;align=center;fontSize=14;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="250" y="110" width="700" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p3_oc" value="OrderController" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="70" y="201" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3_co_module" value="Checkout モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="320" y="150" width="760" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p3_tipcalc" value="static class&#xa;TipCalculator&#xa;+ Calculate(decimal subtotal, decimal rate)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="760" y="191" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p3_rf_module" value="Refunds モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="320" y="430" width="760" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p3_refundsvc" value="class RefundService&#xa;+ Calculate(Order order)&#xa;（コピペされたロジック）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="780" y="526" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p3_dup_rules" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;❌ 重複したビジネスルール&lt;br&gt;&lt;br&gt;• rate ∈ [0, 1] のガード&lt;br&gt;• Math.Round(..., 2) — 小数第2位丸め&lt;br&gt;• subtotal × rate のチップ計算&lt;br&gt;• subtotal + tip の合計計算&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fde9e9;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="691" y="350" width="309" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p3_e1" value="利用" style="endArrow=open;html=1;fontSize=11;rounded=0;" parent="1" source="p3_oc" target="p3_tipcalc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_dup_line" value="コピペで重複 ⚠" style="endArrow=none;html=1;dashed=1;dashPattern=8 4;strokeColor=#b85450;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#b85450;entryX=1;entryY=0.15;entryDx=0;entryDy=0;entryPerimeter=0;exitX=0.997;exitY=0.92;exitDx=0;exitDy=0;exitPerimeter=0;" parent="1" edge="1" target="p3_refundsvc" source="p3_tipcalc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1060" y="330" as="sourcePoint" />
            <mxPoint x="1060" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_anno" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;❌ 同じビジネスルールが TipCalculator と RefundService の両方に重複 — どちらかが変更されたとき追随漏れが発生&lt;br&gt;→ 「機能結合（重複した機能）」 — grep でも追えない暗黙の結合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde9e9;strokeColor=#b85450;fontSize=12;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" parent="1" vertex="1">
          <mxGeometry x="140" y="690" width="850" height="80" as="geometry" />
        </mxCell>
        <mxCell id="jWfOwo0JKtxh-NSsjt34-2" value="&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 13px;&quot;&gt;✗&amp;nbsp;（削除された 契約）&amp;nbsp;ITipCalculator&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=center;verticalAlign=middle;dashed=1;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="390" y="269" width="280" height="42" as="geometry" />
        </mxCell>
        <mxCell id="QfzQq06onyGuEHyUloSY-1" value="&lt;div&gt;&lt;font&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 13px;&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: transparent;&quot;&gt;✗&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: transparent;&quot;&gt;（削除された モデル）&lt;/span&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 13px;&quot;&gt;&lt;font&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: transparent;&quot;&gt;：&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;TipRate,&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Money,&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;等&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=center;verticalAlign=middle;dashed=1;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="390" y="320" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="QfzQq06onyGuEHyUloSY-2" value="RefuncsController" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="71" y="537" width="200" height="80" as="geometry" />
