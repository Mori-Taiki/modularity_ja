        </mxCell>
        <mxCell id="p2_subtitle" value="Facade を消した — 利用側に内部の計算器構造が漏出" style="text;html=1;align=center;fontSize=14;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="230" y="210" width="710" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p2_oc" value="OrderController&#xa;(利用側)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="130" y="360" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_module" value="Checkout モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="380" y="260" width="650" height="400" as="geometry" />
        </mxCell>
        <mxCell id="p2_removed" value="✗ ICheckoutWorkflow&#xa;（削除された Facade）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=center;verticalAlign=middle;dashed=1;fontColor=#999999;" parent="1" vertex="1">
          <mxGeometry x="400" y="310" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_itip" value="«interface» public ⬆&#xa;ITipCalculator&#xa;+ ApplyTo(Money, TipRate) : Money" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="760" y="350" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2_ptip" value="public class ⬆&#xa;PercentageTipCalculator" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="760" y="510" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_e1" value="依存 (内部計算器を直接利用)" style="endArrow=open;html=1;fontSize=11;rounded=0;" parent="1" source="p2_oc" target="p2_itip" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e2" value="実装" style="endArrow=block;endFill=0;dashed=1;html=1;fontSize=11;rounded=0;" parent="1" source="p2_ptip" target="p2_itip" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_anno" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;⚠ 利用側が知っているもの: 内部計算器の存在 + Money / TipRate の構造&lt;br&gt;⚠ 失われたもの: Checkout チームが内部の「部品構成」を自由に変更する権利&lt;br&gt;⚠ 新たに ITaxCalculator が増えると、利用側もそれを足し合わせる必要がある&lt;br&gt;→ 「契約結合」が「モデル結合」に変化した&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e0;strokeColor=#d79b00;fontSize=12;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" parent="1" vertex="1">
          <mxGeometry x="180" y="700" width="850" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="③機能結合" id="-AHYYgKb1Jw7LWpk8eX9">
