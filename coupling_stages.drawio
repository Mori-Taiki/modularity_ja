  <diagram name="①契約結合 (Contract)" id="p1">
    <mxGraphModel dx="1291" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1_title" value="ステージ1 ✅ 契約結合 (Contract Coupling)" style="text;html=1;align=center;fontSize=22;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="268" y="50" width="630" height="35" as="geometry" />
        </mxCell>
        <mxCell id="p1_subtitle" value="初期設計 — 利用側はインターフェースの「契約」だけを知っている" style="text;html=1;align=center;fontSize=14;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="198" y="90" width="700" height="25" as="geometry" />
        </mxCell>
        <mxCell id="p1_oc" value="OrderController&#xa;(利用側)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="40" y="210" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1_module" value="　　Checkout モジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#36393d;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;spacingTop=8;" parent="1" vertex="1">
          <mxGeometry x="288" y="150" width="660" height="430" as="geometry" />
        </mxCell>
        <mxCell id="p1_iface" value="«interface» public&lt;br&gt;ICheckoutWorkflow&lt;br&gt;+ Finalize(Order) : Receipt&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;（契約）&lt;/font&gt;&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="308" y="200" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p1_workflow" value="«internal» class&#xa;CheckoutWorkflow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="353" y="347" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1_itip" value="«interface» internal&#xa;ITipCalculator&#xa;+ Calculate(Money, TipRate) : Money" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="653" y="337" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p1_ptip" value="«internal» class&#xa;PercentageTipCalculator" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="668" y="480" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1_e1" value="依存" style="endArrow=open;html=1;fontSize=11;rounded=0;" parent="1" source="p1_oc" target="p1_iface" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e2" value="実装" style="endArrow=block;endFill=0;dashed=1;html=1;fontSize=11;rounded=0;" parent="1" source="p1_workflow" target="p1_iface" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e3" value="利用" style="endArrow=open;html=1;fontSize=11;rounded=0;" parent="1" source="p1_workflow" target="p1_itip" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e4" value="実装" style="endArrow=block;endFill=0;dashed=1;html=1;fontSize=11;rounded=0;" parent="1" source="p1_ptip" target="p1_itip" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_anno" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;✅ 利用側が知っているのは ICheckoutWorkflow.Finalize の シグネチャ のみ&lt;br&gt;✅ 内部の計算器（ITipCalculator / PercentageTipCalculator）は internal で隠蔽&lt;br&gt;✅ Checkout チームは契約面さえ守れば、内部実装を自由に変更できる&lt;br&gt;→ 変動性の高いコアサブドメインに対する正しい投資&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=12;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" parent="1" vertex="1">
          <mxGeometry x="118" y="620" width="750" height="120" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="②モデル結合 (Model)" id="p2">
    <mxGraphModel dx="1291" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
