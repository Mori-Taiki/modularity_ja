  <diagram name="④機能結合-制御 (Functional-Control)" id="p4">
    <mxGraphModel dx="1236" dy="858" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4_title" parent="1" style="text;html=1;align=center;fontSize=22;fontStyle=1;" value="ステージ4 ❌ 機能結合 (Functional Coupling) — 制御結合" vertex="1">
